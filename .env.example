# Science Radar Configuration
# Topic to monitor (change this to switch topics)
# TOPIC = "GMO and genome editing in agriculture"

# Model names
SCOUT_MODEL   = "anthropic/claude-haiku-4-5"
CRITIC_MODEL  = "anthropic/claude-sonnet-4-6"
CURATOR_MODEL = "anthropic/claude-opus-4-6"
WRITER_MODEL  = "anthropic/claude-sonnet-4-6"
